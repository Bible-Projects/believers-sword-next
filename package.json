{
  "name": "believers-sword-nightly",
  "description": "Believers Sword is an application for believers community, it is used to study bible, also used for praying, social or connect with other believers.",
  "author": "JenuelDev",
  "version": "1.2.5",
  "main": "./dist/main.js",
  "license": "GPL-3.0",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit && cd FrontEndApp && yarn typecheck",
    "typecheck:electron": "tsc --noEmit",
    "typecheck:frontend": "cd FrontEndApp && yarn typecheck",
    "watch": "nodemon --exec yarn serve:electron",
    "start": "yarn nightly:rename && concurrently -k \"yarn serve:front\" \"yarn watch\"",
    "front:setup": "cd FrontEndApp && yarn",
    "electron:setup": "yarn",
    "setup": "yarn electron:setup && yarn front:setup",
    "serve:front": "cd FrontEndApp && yarn dev",
    "serve:electron": "set APP_IS_NIGHTLY=yes && set APP_IS_DEV=yes && yarn build && wait-on tcp:3000 && electron .",
    "build:front": "cd FrontEndApp && yarn build",
    "electron:build": "yarn build",
    "electron:builder": "electron-builder",
    "app:build": "yarn prod:rename && yarn build:front && yarn electron:build && yarn electron:builder",
    "app:build:nightly": "set APP_IS_NIGHTLY=yes && set APP_IS_DEV=no && yarn nightly:rename && yarn build:front && yarn electron:build && yarn electron:builder",
    "app:build:msix": "yarn prod:rename && yarn build:front && yarn electron:build && yarn electron:builder --win appx",
    "app:build:msix:nightly": "set APP_IS_NIGHTLY=yes && set APP_IS_DEV=no && yarn nightly:rename && yarn build:front && yarn electron:build && yarn electron:builder --win appx",
    "nightly:rename": "json -I -f package.json -e \"this.name='believers-sword-nightly'\" && json -I -f package.json -e \"this.build.productName='Believers Sword Nightly'\" && json -I -f package.json -e \"this.build.appId='com.official-believers-sword-nightly.app'\"",
    "prod:rename": "json -I -f package.json -e \"this.name='believers-sword'\" && json -I -f package.json -e \"this.build.productName='Believers Sword'\" && json -I -f package.json -e \"this.build.appId='com.official-believers-sword.app'\"",
    "electron-rebuild": "./node_modules/.bin/electron-rebuild",
    "sqlite-rebuild": "cd node_modules/better-sqlite3 && npm run build-release",
    "postinstall": "electron-builder install-app-deps",
    "untag": "node -e \"const v='v'+require('./package.json').version,e=require('child_process').execSync;e('git tag -d '+v,{stdio:'inherit'});e('git push origin :refs/tags/'+v,{stdio:'inherit'})\"",
    "release": "node -e \"const v='v'+require('./package.json').version,e=require('child_process').execSync;e('git tag '+v,{stdio:'inherit'});e('git push origin '+v,{stdio:'inherit'})\"",
    "rerelease": "yarn untag && yarn release"
  },
  "build": {
    "appId": "com.official-believers-sword-nightly.app",
    "productName": "Believers Sword Nightly",
    "copyright": "Copyright © 2022 ${author}",
    "publish": [
      {
        "provider": "github",
        "owner": "JenuelDev",
        "repo": "Believers-Sword"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      "defaults/**/*"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist_electron"
    },
    "portable": {
      "artifactName": "${productName}-v${version}-Portable.exe"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis",
        "portable",
        "appx"
      ]
    },
    "appx": {
      "applicationId": "BelieversSword",
      "publisher": "CN=77A53CA7-0845-448E-8408-E97652135998",
      "publisherDisplayName": "JenuelDev",
      "identityName": "JenuelDev.BelieversSword"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png"
    }
  },
  "dependencies": {
    "dayjs": "^1.11.13",
    "electron-dl": "^3.5.0",
    "electron-log": "^4.4.8",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.1",
    "electron-window-state": "^5.0.3",
    "extract-zip": "^2.0.1",
    "knex": "^3.1.0",
    "sqlite3": "5.1.6",
    "upath": "^2.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.2",
    "concurrently": "^7.4.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-devtools-installer": "^3.2.0",
    "json": "^11.0.0",
    "node-abi": "^4.28.0",
    "nodemon": "^2.0.20",
    "sass": "^1.81.0",
    "typescript": "^5.1.6",
    "vue-tsc": "^1.8.27",
    "wait-on": "^6.0.1"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
